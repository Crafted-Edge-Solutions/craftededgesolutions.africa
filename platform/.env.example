# Copy to .env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,craftededgesolutions.africa,meshack.craftededgesolutions.africa
DJANGO_CSRF_TRUSTED_ORIGINS=https://craftededgesolutions.africa,https://meshack.craftededgesolutions.africa

# Database (leave blank to use SQLite for dev)
# DATABASE_URL=postgres://user:password@localhost:5432/ces_platform

# Wagtail
WAGTAILADMIN_BASE_URL=https://craftededgesolutions.africa

# Email (SMTP)
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=hello@craftededgesolutions.africa
# EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=hello@craftededgesolutions.africa

# Paystack (https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=
# Optional: recurring plan code from Paystack dashboard
PAYSTACK_INSIGHTS_PLAN_CODE=

# Listmonk (running via docker-compose.listmonk.yml in parent dir)
LISTMONK_BASE_URL=http://localhost:9000
LISTMONK_USERNAME=listmonk
LISTMONK_PASSWORD=listmonk
# List ID for the Insights premium subscriber list (check /lists in Listmonk admin)
LISTMONK_LIST_ID_INSIGHTS=1
